# ─────────────────────────────────────────────────────────────────────────────
#  LINE OA Next.js Starter — environment variables
#
#  Copy this file to `.env.local` and fill in the values. NEVER commit `.env.local`.
#  Everything is optional at boot: with no LINE vars set the app still runs and
#  degrades gracefully (the login button is a no-op, pushes log `line_token_not_set`,
#  the webhook still returns 200). Set the vars to go live.
# ─────────────────────────────────────────────────────────────────────────────

# ── LINE Messaging API channel (the Official Account) ────────────────────────
# LINE Developers Console → your Messaging API channel.
# Messaging API tab → "Issue" a long-lived channel access token.
LINE_CHANNEL_ACCESS_TOKEN=
# Basic settings tab → Channel secret. Used to verify the X-Line-Signature on
# every inbound webhook call (rejects forged callbacks).
LINE_CHANNEL_SECRET=

# ── LINE Login channel (for LIFF in-app login) ───────────────────────────────
# LINE Developers Console → your LINE Login channel → Channel ID.
# We check that a LIFF access token was minted for THIS channel before trusting it.
LINE_LOGIN_CHANNEL_ID=
# Public: the LIFF app id (LINE Login channel → LIFF tab → Add). Used by the
# browser SDK and for deep links (liff.line.me/<id><path>).
NEXT_PUBLIC_LIFF_ID=

# ── App URLs ─────────────────────────────────────────────────────────────────
# Public base URL of this deployment. Fallback for deep links when LIFF is unset.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase (self-contained schema — see supabase/migrations) ───────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only service-role key (bypasses RLS). NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Set to "supabase" to use the real DB; anything else keeps the app DB-free
# (routes that need the DB will report they are not configured).
NEXT_PUBLIC_DATA_SOURCE=supabase

# ── Cron / scheduled reminders ───────────────────────────────────────────────
# Shared secret the cron scheduler sends as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=
# UTC offset for all reminder day/hour math. Default 7 = Asia/Bangkok (UTC+7).
# (The send HOUR itself is admin-configurable in the `settings` DB row — see supabase/migrations.)
REMINDER_UTC_OFFSET_HOURS=7

# ── Minimal admin gate ───────────────────────────────────────────────────────
# Shared secret for the demo admin endpoints and the /api/push demo. Send it as
# `Authorization: Bearer <ADMIN_SECRET>`.
ADMIN_SECRET=
